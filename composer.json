{
    "name": "thieleundklose/autotranslate",
    "type": "typo3-cms-extension",
    "description": "This extension provides automatic translation of pages and content elements via DeepL API.",
    "authors": [
        {
            "name": "Mike Zimmer",
            "email": "typo3@thieleundklose.de",
            "homepage": "https://www.thieleundklose.de",
            "role": "Developer"
        }
    ],
    "license": "GPL-2.0-or-later",
    "require": {
        "typo3/cms-core": "^12.4 || ^13.4 || ^14.0",
        "deeplcom/deepl-php": "^1.5",
        "php": ">= 8.1 <= 8.5.99"
    },
    "require-dev": {
        "typo3/testing-framework": "^6.8 || ^7.0 || ^8.2 || ^9.0"
    },
    "autoload": {
        "psr-4": {
            "ThieleUndKlose\\Autotranslate\\": "Classes"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ThieleUndKlose\\Autotranslate\\Tests\\": "Tests"
        }
    },
    "replace": {
        "typo3-ter/autotranslate": "self.version"
    },
    "config": {
        "vendor-dir": ".Build/vendor",
        "bin-dir": ".Build/bin",
        "allow-plugins": {
            "typo3/cms-composer-installers": true,
            "typo3/class-alias-loader": true
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "TYPO3\\TestingFramework\\Composer\\ExtensionTestEnvironment::prepare"
        ],
        "ci:lint:php": [
            "find . -path './.Build' -prune -o -path './Resources/Vendor' -prune -o -name '*.php' -print0 | xargs -0 -n1 php -l"
        ],
        "ci:test:php:unit": [
            "phpunit --configuration Build/UnitTests.xml"
        ],
        "ci:test:php:functional": [
            "phpunit --configuration Build/FunctionalTests.xml"
        ],
        "ci:test": [
            "@ci:test:php:unit",
            "@ci:test:php:functional",
            "@ci:lint:php"
        ]
    },
    "extra": {
        "typo3/cms": {
            "cms-package-dir": "{$vendor-dir}/typo3/cms",
            "web-dir": ".Build/public",
            "extension-key": "autotranslate"
        }
    }
}
